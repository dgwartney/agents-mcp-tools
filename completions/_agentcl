  local context state line

  _arguments -C \
    '1: :_agentcl_platform_evals_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        personas)   _agentcl_platform_evals_resource 'persona' 'list get create update delete templates generate' ;;
        scenarios)  _agentcl_platform_evals_resource 'scenario' 'list get create update delete generate' ;;
        evaluators) _agentcl_platform_evals_resource 'evaluator' 'list get create update delete templates' ;;
        sets)       _agentcl_platform_evals_resource 'set' 'list get create update delete' ;;
        runs)       _agentcl_platform_evals_runs ;;
      esac
      ;;
  esac
}

_agentcl_platform_evals_cmds() {
  local cmds=(
    'personas:Manage eval personas'
    'scenarios:Manage eval scenarios'
    'evaluators:Manage eval evaluators'
    'sets:Manage eval sets'
    'runs:Manage eval runs'
  )
  _describe 'evals command' cmds
}

_agentcl_platform_evals_resource() {
  local resource=$1
  local actions=("${(@s: :)2}")
  local context state line

  _arguments -C \
    "1: :(${actions})" \
    '*:: :->subcmd'

  case $state in
    subcmd)
      _arguments \
        $_agentcl_opt_project \
        "--${resource}-id[${resource} ID]:id:" \
        '--body[Request body (JSON)]:json:' \
        $_agentcl_opt_confirm \
        '(-h --help)'{-h,--help}'[display help]'
      ;;
  esac
}

_agentcl_platform_evals_runs() {
  local context state line
  local run_actions=(list get create update start cancel status heatmap cases compare preflight quick)

  _arguments -C \
    "1: :(${run_actions})" \
    '*:: :->subcmd'

  case $state in
    subcmd)
      _arguments \
        $_agentcl_opt_project \
        '--run-id[Run ID]:id:' \
        '--run-ids[Comma-separated run IDs for compare]:ids:' \
        '--body[Request body (JSON)]:json:' \
        '(-h --help)'{-h,--help}'[display help]'
      ;;
  esac
}

# ─── debug ────────────────────────────────────────────────────────────────────

_agentcl_debug() {
  local context state line

  _arguments -C \
    '1: :_agentcl_debug_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        list-agents)          _agentcl_debug_list_agents ;;
        load-agent)           _agentcl_debug_load_agent ;;
        send-message)         _agentcl_debug_send_message ;;
        traces)               _agentcl_debug_traces ;;
        get-current-state)    _arguments $_agentcl_opt_session $_agentcl_opt_project '(-h --help)'{-h,--help}'[display help]' ;;
        get-span-tree)        _arguments $_agentcl_opt_session $_agentcl_opt_project '--flat[Return flat list with depth info]' '(-h --help)'{-h,--help}'[display help]' ;;
        get-errors)           _arguments $_agentcl_opt_session $_agentcl_opt_project '--include-warnings[Include warnings]' '(-h --help)'{-h,--help}'[display help]' ;;
        explain-decision)     _agentcl_debug_explain_decision ;;
        get-flow-graph)       _agentcl_debug_get_flow_graph ;;
        list-active-sessions) _arguments '(-h --help)'{-h,--help}'[display help]' ;;
        session)              _agentcl_debug_session ;;
        docs)                 _arguments '--topic[Topic name]:topic:' '--query[Search query]:query:' '(-h --help)'{-h,--help}'[display help]' ;;
        analyze-session)      _arguments $_agentcl_opt_session $_agentcl_opt_project '(-h --help)'{-h,--help}'[display help]' ;;
        diagnostic-layer)     _arguments $_agentcl_opt_trace '(-h --help)'{-h,--help}'[display help]' ;;
        get-trace-event)      _agentcl_debug_get_trace_event ;;
        explain-trace-event)  _arguments '--event-id[Event ID]:id:' $_agentcl_opt_trace '(-h --help)'{-h,--help}'[display help]' ;;
        model-interactions)   _arguments $_agentcl_opt_trace '--include-timeline[Include timeline]' '(-h --help)'{-h,--help}'[display help]' ;;
        realtime-interactions) _arguments $_agentcl_opt_trace '--include-timeline[Include timeline]' '(-h --help)'{-h,--help}'[display help]' ;;
        harness-logs)         _agentcl_debug_harness_logs ;;
        diagnose)             _agentcl_debug_diagnose ;;
        lint-abl)             _arguments '--path[Local folder or .zip path]:path:_files' '(-h --help)'{-h,--help}'[display help]' ;;
        why-transcript-failed) _arguments '--path[Package folder or .zip path]:path:_files' '--transcript-path[Transcript JSON file path]:path:_files' '(-h --help)'{-h,--help}'[display help]' ;;
      esac
      ;;
  esac
}

