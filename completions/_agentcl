_agentcl_platform_evals_resource() {
  local idflag="$1"
  local actions=("${(@s: :)2}")
  local context state line

  _arguments -C \
    "1: :(${actions})" \
    '*:: :->subcmd'

  case $state in
    subcmd)
      _arguments \
        '--project-id[Project ID]: : ' \
        "--${idflag}[Resource ID]: : " \
        '--body[Request body (JSON)]: : ' \
        '--confirm[Confirm destructive operation]' \
        '(-h --help)'{-h,--help}'[display help]'
      ;;
  esac
}

_agentcl_platform_evals_runs() {
  local context state line
  local run_actions=(list get create update start cancel status heatmap cases compare preflight quick)

  _arguments -C \
    "1: :(${run_actions})" \
    '*:: :->subcmd'

  case $state in
    subcmd)
      _arguments \
        '--project-id[Project ID]: : ' \
        '--run-id[Run ID]: : ' \
        '--run-ids[Comma-separated run IDs for compare]: : ' \
        '--body[Request body (JSON)]: : ' \
        '(-h --help)'{-h,--help}'[display help]'
      ;;
  esac
}

# ─── debug ────────────────────────────────────────────────────────────────────

_agentcl_debug() {
  local context state line

  _arguments -C \
    '1: :_agentcl_debug_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        list-agents)           _arguments '--domain[Filter by domain]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        load-agent)            _arguments '--agent-path[Agent path (domain/name)]: : ' '--project-id[Project ID]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        send-message)          _agentcl_debug_send_message ;;
        traces)                _agentcl_debug_traces ;;
        get-current-state)     _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        get-span-tree)         _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--flat[Return flat list with depth info]' '(-h --help)'{-h,--help}'[display help]' ;;
        get-errors)            _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--include-warnings[Include warnings]' '(-h --help)'{-h,--help}'[display help]' ;;
        explain-decision)      _agentcl_debug_explain_decision ;;
        get-flow-graph)        _agentcl_debug_get_flow_graph ;;
        list-active-sessions)  _arguments '(-h --help)'{-h,--help}'[display help]' ;;
        session)               _agentcl_debug_session ;;
        docs)                  _arguments '--topic[Topic name]: : ' '--query[Search query]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        analyze-session)       _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        diagnostic-layer)      _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--trace-limit[Max trace events]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        get-trace-event)       _agentcl_debug_get_trace_event ;;
        explain-trace-event)   _arguments '--event-id[Event ID]: : ' '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--trace-limit[Max trace events]: : ' '(-h --help)'{-h,--help}'[display help]' ;;
        model-interactions)    _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--trace-limit[Max trace events]: : ' '--include-timeline[Include timeline]' '(-h --help)'{-h,--help}'[display help]' ;;
        realtime-interactions) _arguments '--session-id[Session ID]: : ' '--project-id[Project ID]: : ' '--trace-limit[Max trace events]: : ' '--include-timeline[Include timeline]' '(-h --help)'{-h,--help}'[display help]' ;;
        harness-logs)          _agentcl_debug_harness_logs ;;
        diagnose)              _agentcl_debug_diagnose ;;
        lint-abl)              _arguments '--path[Local folder or .zip path]:path:_files' '(-h --help)'{-h,--help}'[display help]' ;;
        why-transcript-failed) _arguments '--path[Package folder or .zip path]:path:_files' '--transcript-path[Transcript JSON path]:path:_files' '(-h --help)'{-h,--help}'[display help]' ;;
      esac
      ;;
  esac
}

