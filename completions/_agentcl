#compdef agentcl
# Zsh completion for agentcl — Arch Agent Platform CLI
#
# Installation (Homebrew — already in $fpath on macOS):
#   cp completions/_agentcl $(brew --prefix)/share/zsh/site-functions/_agentcl
#   rm -f ~/.zcompdump && compinit

# ─── Shared option sets ───────────────────────────────────────────────────────

_agentcl_opt_project=(
  '--project-id[Project ID (resolved from .arch/state.json if not set)]: : '
)

_agentcl_opt_session=(
  '--session-id[Session ID (resolved from .arch/state.json if not set)]: : '
)

_agentcl_opt_agent=(
  '--agent-name[Agent name]: : '
)

_agentcl_opt_global=(
  '--global[Write to global ~/.config/kore-platform/cli-state.json]'
)

_agentcl_opt_confirm=(
  '--confirm[Confirm destructive operation]'
)

_agentcl_opt_trace=(
  '--session-id[Session ID]: : '
  '--project-id[Project ID]: : '
  '--trace-limit[Max trace events to load]: : '
)

# ─── Top-level ────────────────────────────────────────────────────────────────

_agentcl() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-V --version)'{-V,--version}'[output version number]' \
    '--server-url[Server URL (overrides AGENTS_URL env var)]: : ' \
    '1: :_agentcl_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        platform) _agentcl_platform ;;
        debug)    _agentcl_debug ;;
        context)  _agentcl_context ;;
      esac
      ;;
  esac
}

_agentcl_cmds() {
  local cmds=(
    'platform:Manage Arch platform resources'
    'debug:Debug agent sessions and traces'
    'context:Manage saved CLI context (project ID, session ID, workspace)'
    'help:Display help for a command'
  )
  _describe 'command' cmds
}

# ─── platform ─────────────────────────────────────────────────────────────────

_agentcl_platform() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '1: :_agentcl_platform_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        connect)          _agentcl_platform_connect ;;
        projects)         _agentcl_platform_projects ;;
        agents)           _agentcl_platform_agents ;;
        versions)         _agentcl_platform_versions ;;
        deployments)      _agentcl_platform_deployments ;;
        tools)            _agentcl_platform_tools ;;
        config)           _agentcl_platform_config ;;
        workspaces)       _agentcl_platform_workspaces ;;
        import-export)    _agentcl_platform_import_export ;;
        validate-package) _agentcl_platform_validate_package ;;
        package-model)    _agentcl_platform_package_model ;;
        evals)            _agentcl_platform_evals ;;
      esac
      ;;
  esac
}

_agentcl_platform_cmds() {
  local cmds=(
    'connect:Connect to the Arch platform and authenticate'
    'projects:Manage projects'
    'agents:Manage agents within a project'
    'versions:Manage agent versions'
    'deployments:Manage deployments'
    'tools:Manage platform tools'
    'config:Manage project configuration'
    'workspaces:Manage workspaces (tenants)'
    'import-export:Import and export projects'
    'validate-package:Validate a local ABL project package'
    'package-model:Show compiler model for a local package'
    'evals:Manage evaluations'
  )
  _describe 'platform command' cmds
}

_agentcl_platform_connect() {
  _arguments \
    '--server-url[Server URL]: : ' \
    '--auth-token[Explicit JWT token]: : ' \
    '--force[Force disconnect and reconnect — clears stored credentials]' \
    '--device-code[Device code from prior auth initiation]: : ' \
    '(-h --help)'{-h,--help}'[display help]'
}

_agentcl_platform_projects() {
  local context state line
  typeset -A opt_args

  _arguments -C \
    '1: :_agentcl_platform_projects_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        list)   _arguments '(-h --help)'{-h,--help}'[display help]' ;;
        get)    _arguments $(_agentcl_expand _agentcl_opt_project) '(-h --help)'{-h,--help}'[display help]' ;;
        create) _agentcl_platform_projects_create ;;
        update) _agentcl_platform_projects_update ;;
        delete) _arguments $(_agentcl_expand _agentcl_opt_project) '--confirm[Confirm destructive operation]' '(-h --help)'{-h,--help}'[display help]' ;;
      esac
      ;;
  esac
}

# Helper: expand a named option array
_agentcl_expand() {
  local arr="$1[@]"
  echo "${(P)arr}"
}

