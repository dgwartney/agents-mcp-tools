  _arguments -C \
    '1: :_agentcl_context_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        show)          _arguments $_agentcl_opt_global '(-h --help)'{-h,--help}'[display help]' ;;
        set-project)   _arguments '--project-id[Project ID to save]:id:' $_agentcl_opt_global '(-h --help)'{-h,--help}'[display help]' ;;
        set-session)   _arguments '--session-id[Session ID to save]:id:' $_agentcl_opt_global '(-h --help)'{-h,--help}'[display help]' ;;
        set-workspace) _arguments '--tenant-id[Tenant ID to save]:id:' '--workspace-name[Workspace display name]:name:' $_agentcl_opt_global '(-h --help)'{-h,--help}'[display help]' ;;
        clear)         _arguments $_agentcl_opt_global '(-h --help)'{-h,--help}'[display help]' ;;
      esac
      ;;
  esac
}

