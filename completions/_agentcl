# ─── context ──────────────────────────────────────────────────────────────────

_agentcl_context() {
  local context state line

  _arguments -C \
    '1: :_agentcl_context_cmds' \
    '*:: :->subcmd'

  case $state in
    subcmd)
      case $words[1] in
        show)          _arguments '--global[Show global state file]' '(-h --help)'{-h,--help}'[display help]' ;;
        set-project)   _arguments '--project-id[Project ID to save]: : ' '--global[Write to global state]' '(-h --help)'{-h,--help}'[display help]' ;;
        set-session)   _arguments '--session-id[Session ID to save]: : ' '--global[Write to global state]' '(-h --help)'{-h,--help}'[display help]' ;;
        set-workspace) _arguments '--tenant-id[Tenant ID to save]: : ' '--workspace-name[Workspace display name]: : ' '--global[Write to global state]' '(-h --help)'{-h,--help}'[display help]' ;;
        clear)         _arguments '--global[Clear global state file]' '(-h --help)'{-h,--help}'[display help]' ;;
      esac
      ;;
  esac
}

_agentcl_context_cmds() {
  local cmds=(
    'show:Display active state file path and saved values'
    'set-project:Save a default project ID'
    'set-session:Save a default session ID'
    'set-workspace:Save a default workspace (tenant)'
    'clear:Clear all saved context'
  )
  _describe 'context command' cmds
}

